# ------------------------------
# Lavalink core
# ------------------------------
LAVALINK_PORT=2333
LAVALINK_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
LAVALINK_RESUME_KEY=CHANGE_ME_TO_ANOTHER_LONG_RANDOM_SECRET

# ------------------------------
# Source APIs
# ------------------------------
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
APPLE_MUSIC_TOKEN=your_apple_music_jwt_token
DEEZER_ARL=

# ------------------------------
# Java tuning (2 vCPU / 4GB host)
# ------------------------------
JAVA_TOOL_OPTIONS=-Xms768m -Xmx1536m -XX:+UseG1GC -XX:MaxGCPauseMillis=100 -XX:InitiatingHeapOccupancyPercent=30 -XX:G1ReservePercent=20 -XX:ParallelGCThreads=2 -XX:ConcGCThreads=1 -XX:+AlwaysPreTouch -XX:+DisableExplicitGC -Dfile.encoding=UTF-8 -Dsun.jnu.encoding=UTF-8

# ------------------------------
# Optional bot-side env examples
# ------------------------------
# LAVALINK_HOST=127.0.0.1
# DISCORD_TOKEN=your_bot_token
